# Repo root — copy to `.env` (gitignored). Bun loads `.env` from cwd on `bun run`.

# Agent test live dogfood: `npm run agent:test:live -- --suite routing`
# Verbose live debug (staging under $TMPDIR/agent-spec by default): `npm run agent:test:live:debug`
# Optional custom staging parent (prefer outside repo): `npm run agent:test:live:debug -- --debug-dir "$TMPDIR/agent-test-debug"`

# Cursor SDK + harness LLM judge (not Anthropic/Claude API — Claude adapter is stubbed).

CURSOR_API_KEY=

# Optional: local SDK model (default auto)

CURSOR_AGENT_MODEL=

# Optional: skip per-scenario git worktrees for live runs

# AGENT_TEST_NO_WORKTREE=1
