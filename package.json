{
	"name": "toolbox",
	"version": "1.0.0",
	"description": "Public SSOT for team Cursor/Claude agent skills.",
	"main": "index.js",
	"directories": {
		"doc": "docs"
	},
	"scripts": {
		"references:sync": "skeleton references sync",
		"references:check": "skeleton references check",
		"audit:hub": "skeleton audit docs --paths=README.md,docs",
		"audit:docs": "skeleton audit docs",
		"audit:skills": "skeleton audit skills",
		"audit:self": "skeleton audit self",
		"validate:changed": "skeleton validate changed",
		"validate:ci": "skeleton validate changed --base origin/main",
		"test": "npm run references:check && npm run audit:hub && npm run audit:skills && npm run validate:ci"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/csark0812/toolbox.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/csark0812/toolbox/issues"
	},
	"homepage": "https://github.com/csark0812/toolbox#readme",
	"devDependencies": {
		"@csark0812/skeleton": "^1.1.0"
	}
}
